{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": ["node", "react"],
    "lib": ["es2022", "dom"]
  },
  "include": [
    "src/commands/wizard/ui/**/*",
    "src/commands/wizard/types.ts",
    "src/commands/connect/ui/**/*",
    "src/commands/connect/types.ts"
  ],
  "exclude": ["node_modules"]
}
